# Night Watcher — environment variables for Tailscale + TLS
#
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# The .env file is loaded automatically by Docker Compose.
# NEVER commit .env to git — it contains your auth key.

# ── Tailscale ─────────────────────────────────────────────────────────────────
# Auth key from https://login.tailscale.com/admin/settings/keys
# Use a reusable or ephemeral key (ephemeral preferred for servers).
TS_AUTHKEY=tskey-auth-...

# Hostname this machine will register as in your tailnet.
# After connecting, the FQDN will be <TS_HOSTNAME>.<tailnet>.ts.net
TS_HOSTNAME=night-watcher-pi

# ── Public HTTPS URLs ─────────────────────────────────────────────────────────
# Set these AFTER running `tailscale status` on the Pi to learn the FQDN.
# Example: night-watcher-pi.tail1a2b3c.ts.net
#
# The Streamlit dashboard uses these to build browser-facing links for the
# MJPEG stream, video playback, and Grafana panels.
TS_FQDN=night-watcher-pi.your-tailnet.ts.net
